#!/usr/bin/env bash
# tmux plugin for ez-workspaces
# Creates/attaches/detaches tmux sessions for workspace sessions.
# Provides a "tmux" view listing ez-managed tmux sessions.
#
# Protocol: reads JSON request from stdin, writes JSON response to stdout.

set -euo pipefail

# Debug logger: ez sets EZ_PLUGIN_DEBUG_LOG to a per-invocation path when
# invoked with --debug. Without that env var, dbg() is a no-op so production
# runs stay silent. Initialize the file with a header on first call.
_dbg_initialized=
dbg() {
    [ -n "${EZ_PLUGIN_DEBUG_LOG:-}" ] || return 0
    if [ -z "$_dbg_initialized" ]; then
        _dbg_initialized=1
        printf '=== tmux-plugin debug log (pid=%s hook=%s) ===\n' "$$" "${HOOK:-?}" >> "$EZ_PLUGIN_DEBUG_LOG"
    fi
    printf '%s\n' "$*" >> "$EZ_PLUGIN_DEBUG_LOG"
}

# Run a tmux command and log argv + rc + combined output. Echoes the output
# to stdout so callers can still capture it.
dbg_tmux() {
    if [ -z "${EZ_PLUGIN_DEBUG_LOG:-}" ]; then
        tmux "$@"
        return $?
    fi
    local out rc
    out=$(tmux "$@" 2>&1) || rc=$?
    rc=${rc:-0}
    dbg "tmux $* -> rc=$rc out='$out'"
    [ -n "$out" ] && printf '%s\n' "$out"
    return $rc
}

REQUEST=$(cat)

HOOK=$(echo "$REQUEST" | jq -r '.hook')
REPO_NAME=$(echo "$REQUEST" | jq -r '.repo.path' | xargs basename 2>/dev/null || echo "")
REPO_ID=$(echo "$REQUEST" | jq -r '.repo.id // empty')
SESSION_ID=$(echo "$REQUEST" | jq -r '.session.id // empty')
SESSION_NAME=$(echo "$REQUEST" | jq -r '.session.name // empty')
SESSION_PATH=$(echo "$REQUEST" | jq -r '.session.path // .repo.path')
AUTO_ATTACH=$(echo "$REQUEST" | jq -r '.config.user_config.auto_attach // "false"')

# Tmux session name: <repo>/<session>. Identification of ez-managed tmux
# sessions happens via tmux user options (@ez_managed=1) — see on_session_create.
# tmux uses ":" as a target separator and dots confuse some tooling, so
# replace both with "_".
TMUX_SESSION="${REPO_NAME}/${SESSION_NAME}"
TMUX_SESSION=$(echo "$TMUX_SESSION" | tr '.:' '__')

# Use "=" prefix for exact matching — without it tmux treats the name as a
# prefix and "foo/bar" would match "foo/bar-baz".
TMUX_SESSION_TARGET="=${TMUX_SESSION}"

# Build `-e KEY=VALUE` flags from session.env for tmux new-session.
# Populates the ENV_FLAGS array.
build_env_flags() {
    ENV_FLAGS=()
    local env_pairs
    env_pairs=$(echo "$REQUEST" | jq -r '.session.env // {} | to_entries[] | "\(.key)=\(.value)"')
    if [ -n "$env_pairs" ]; then
        while IFS= read -r pair; do
            [ -z "$pair" ] && continue
            ENV_FLAGS+=(-e "$pair")
        done <<< "$env_pairs"
    fi
    dbg "env_flags: ${ENV_FLAGS[*]:-<none>}"
}

# Mark a tmux session as ez-managed by setting user options.
# Args: $1 = tmux session name
mark_ez_managed() {
    local sess="$1"
    dbg "--- mark_ez_managed sess='${sess}' ---"

    dbg_tmux set-option -t "${sess}" @ez_managed "1"                  >/dev/null || true
    dbg_tmux set-option -t "${sess}" @ez_repo_id "${REPO_ID}"         >/dev/null || true
    dbg_tmux set-option -t "${sess}" @ez_session_id "${SESSION_ID}"   >/dev/null || true
    dbg_tmux set-option -t "${sess}" @ez_session_name "${SESSION_NAME}" >/dev/null || true
    dbg_tmux set-option -t "${sess}" @ez_session_path "${SESSION_PATH}" >/dev/null || true
}

case "$HOOK" in
    on_session_create)
        # Create tmux session if tmux is running
        if command -v tmux &>/dev/null; then
            dbg "env: TMUX='${TMUX:-}' TMUX_PANE='${TMUX_PANE:-}' TMUX_TMPDIR='${TMUX_TMPDIR:-}'"
            dbg "target session: '${TMUX_SESSION}'"
            dbg "session path: '${SESSION_PATH}'"

            if [ -n "${EZ_PLUGIN_DEBUG_LOG:-}" ]; then
                dbg "before: list-sessions:"
                dbg_tmux list-sessions -F '  #{session_name}' >/dev/null || true
            fi

            if ! tmux has-session -t "${TMUX_SESSION_TARGET}" 2>/dev/null; then
                build_env_flags
                dbg_tmux new-session -d -s "$TMUX_SESSION" -c "$SESSION_PATH" ${ENV_FLAGS[@]+"${ENV_FLAGS[@]}"} >/dev/null || true
            else
                dbg "session already exists, skipping new-session"
            fi

            if [ -n "${EZ_PLUGIN_DEBUG_LOG:-}" ]; then
                dbg "after: list-sessions:"
                dbg_tmux list-sessions -F '  #{session_name}' >/dev/null || true
            fi

            mark_ez_managed "${TMUX_SESSION_TARGET}"
        fi

        jq -n \
            --arg tmux_session "$TMUX_SESSION" \
            '{
                success: true,
                session_mutations: {
                    env: {
                        EZ_TMUX_SESSION: $tmux_session
                    },
                    plugin_state: {
                        tmux_session: $tmux_session
                    }
                }
            }'
        ;;

    on_session_delete)
        if command -v tmux &>/dev/null; then
            if ! tmux kill-session -t "${TMUX_SESSION_TARGET}" 2>/dev/null; then
                dbg "kill-session failed for '${TMUX_SESSION}', retrying in 500ms"
                sleep 0.5
                tmux kill-session -t "${TMUX_SESSION_TARGET}" 2>/dev/null || true
            fi
        fi
        echo '{"success": true}'
        ;;

    on_session_enter)
        COMMANDS=()
        if command -v tmux &>/dev/null && [ "$AUTO_ATTACH" = "true" ]; then
            ATTACH="if [ -n \"\$TMUX\" ]; then tmux switch-client -t \"${TMUX_SESSION_TARGET}\"; else tmux attach-session -t \"${TMUX_SESSION_TARGET}\"; fi"
            if tmux has-session -t "${TMUX_SESSION_TARGET}" 2>/dev/null; then
                COMMANDS+=("$ATTACH")
            else
                ENV_ARGS=""
                while IFS= read -r pair; do
                    [ -z "$pair" ] && continue
                    ENV_ARGS+=" -e '${pair}'"
                done < <(echo "$REQUEST" | jq -r '.session.env // {} | to_entries[] | "\(.key)=\(.value)"')
                COMMANDS+=("tmux new-session -d -s \"${TMUX_SESSION}\" -c \"${SESSION_PATH}\"${ENV_ARGS} && ${ATTACH}")
            fi
        fi

        if [ ${#COMMANDS[@]} -gt 0 ]; then
            jq -n \
                --argjson cmds "$(printf '%s\n' "${COMMANDS[@]}" | jq -R . | jq -s .)" \
                '{success: true, post_shell_commands: $cmds}'
        else
            echo '{"success": true}'
        fi
        ;;

    on_session_rename)
        OLD_NAME=$(echo "$REQUEST" | jq -r '.rename_context.old_name // empty')
        NEW_NAME=$(echo "$REQUEST" | jq -r '.rename_context.new_name // empty')

        if [ -z "$OLD_NAME" ] || [ -z "$NEW_NAME" ]; then
            echo '{"success": true}'
            exit 0
        fi

        OLD_TMUX="${REPO_NAME}/${OLD_NAME}"
        OLD_TMUX=$(echo "$OLD_TMUX" | tr '.:' '__')
        NEW_TMUX="${REPO_NAME}/${NEW_NAME}"
        NEW_TMUX=$(echo "$NEW_TMUX" | tr '.:' '__')

        dbg "on_session_rename: OLD_TMUX='${OLD_TMUX}' NEW_TMUX='${NEW_TMUX}'"

        if command -v tmux &>/dev/null; then
            if tmux has-session -t "=${OLD_TMUX}" 2>/dev/null; then
                dbg_tmux rename-session -t "=${OLD_TMUX}" "${NEW_TMUX}" >/dev/null || true
                mark_ez_managed "=${NEW_TMUX}"
            else
                dbg "tmux session '${OLD_TMUX}' not found, skipping rename"
            fi
        fi

        echo '{"success": true}'
        ;;

    on_session_exit)
        echo '{"success": true}'
        ;;

    on_bind)
        # alt-a in session picker: create tmux session if needed, then attach
        if ! command -v tmux &>/dev/null; then
            echo '{"success": false, "error": "tmux not installed"}'
            exit 0
        fi

        build_env_flags
        if ! tmux has-session -t "${TMUX_SESSION_TARGET}" 2>/dev/null; then
            tmux new-session -d -s "$TMUX_SESSION" -c "$SESSION_PATH" ${ENV_FLAGS[@]+"${ENV_FLAGS[@]}"} 2>&1 >&2 || true
        else
            # Session already exists — push env vars so new panes inherit them
            echo "$REQUEST" | jq -r '.session.env // {} | to_entries[] | "\(.key)\t\(.value)"' | while IFS=$'\t' read -r key val; do
                [ -z "$key" ] && continue
                tmux set-environment -t "${TMUX_SESSION_TARGET}" "$key" "$val" 2>/dev/null || true
                dbg "set-environment -t $TMUX_SESSION $key=$val"
            done
        fi
        mark_ez_managed "${TMUX_SESSION_TARGET}"

        CMD="if [ -n \"\$TMUX\" ]; then tmux switch-client -t \"${TMUX_SESSION_TARGET}\"; else tmux attach-session -t \"${TMUX_SESSION_TARGET}\"; fi"
        jq -n --arg cmd "$CMD" '{success: true, post_shell_commands: [$cmd]}'
        ;;

    on_view)
        # List all ez sessions across all repos. The tmux session for each is
        # ez:<repo-basename>/<session-name>. Mark sessions whose tmux session
        # is currently running. on_view_select will create-then-attach for any
        # session whose tmux counterpart is missing.
        if ! command -v tmux &>/dev/null; then
            echo '{"success": true, "view_items": [], "view_prompt": "tmux (not installed)"}'
            exit 0
        fi

        EZ_CONFIG_DIR="${EZ_CONFIG_DIR:-$HOME/.config/ez}"
        REPOS_DIR="${EZ_CONFIG_DIR}/repos"
        INDEX_FILE="${REPOS_DIR}/index.toml"

        # Build set of running ez-managed tmux session names (one per line),
        # identified by the @ez_managed user option set in on_session_create.
        RUNNING=$(tmux list-sessions -F '#{session_name}|#{@ez_managed}' 2>/dev/null \
            | { awk -F'|' '$2 == "1" { print $1 }' || true; } || true)

        # Collect all sessions from all registered repos by parsing index.toml
        # for (id, path) pairs, then reading each repo's sessions.toml.
        ALL_SESSIONS_FILE=$(mktemp)
        trap 'rm -f "$ALL_SESSIONS_FILE"' EXIT

        if [ -f "$INDEX_FILE" ]; then
            # Parse [[repos]] entries: each block has id and path fields.
            awk '
                /^\[\[repos\]\]/ { id=""; path=""; next }
                /^id = / { gsub(/^id = "|"$/, "", $0); id=$0 }
                /^path = / { gsub(/^path = "|"$/, "", $0); path=$0 }
                /^$/ && id != "" && path != "" {
                    print id "|" path; id=""; path=""
                }
                END {
                    if (id != "" && path != "") print id "|" path
                }
            ' "$INDEX_FILE" | while IFS='|' read -r repo_id repo_path; do
                [ -z "$repo_id" ] && continue
                sessions_file="${REPOS_DIR}/${repo_id}/sessions.toml"
                [ -f "$sessions_file" ] || continue
                repo_basename=$(basename "$repo_path")

                awk -v repo_basename="$repo_basename" -v repo_path="$repo_path" '
                    /^\[\[sessions\]\]/ { in_session=1; name=""; path=""; next }
                    /^\[\[/ { in_session=0 }
                    in_session && /^name = / {
                        gsub(/^name = "|"$/, "", $0); name=$0
                    }
                    in_session && /^path = / {
                        gsub(/^path = "|"$/, "", $0); path=$0
                    }
                    /^$/ && in_session && name != "" {
                        if (path == "") path = repo_path
                        tmux_name = repo_basename "/" name
                        gsub(/[.:]/, "_", tmux_name)
                        print tmux_name "|" repo_basename "|" name "|" path
                        in_session=0; name=""; path=""
                    }
                    END {
                        if (in_session && name != "") {
                            if (path == "") path = repo_path
                            tmux_name = repo_basename "/" name
                            gsub(/[.:]/, "_", tmux_name)
                            print tmux_name "|" repo_basename "|" name "|" path
                        }
                    }
                ' "$sessions_file" >> "$ALL_SESSIONS_FILE"
            done
        fi
        ALL_SESSIONS=$(cat "$ALL_SESSIONS_FILE")

        # Build JSON items array
        ITEMS=$(printf '%s\n' "$ALL_SESSIONS" \
            | grep -v '^$' \
            | while IFS='|' read -r tmux_name repo_name session_name session_path; do
                [ -z "$tmux_name" ] && continue
                running="○"
                if echo "$RUNNING" | grep -Fxq "$tmux_name"; then
                    running="●"
                fi
                display="  ${running} ${repo_name}/${session_name}"
                # Stash session_path in value as "name|path" so on_view_select
                # can create the tmux session in the right directory.
                value="${tmux_name}|${session_path}"
                jq -n --arg d "$display" --arg v "$value" '{display: $d, value: $v}'
            done \
            | jq -s '.')

        if [ -z "$ITEMS" ] || [ "$ITEMS" = "null" ]; then
            ITEMS="[]"
        fi

        jq -n \
            --argjson items "$ITEMS" \
            '{
                success: true,
                view_items: $items,
                view_prompt: "tmux"
            }'
        ;;

    on_view_select)
        SELECTED=$(echo "$REQUEST" | jq -r '.view_context.selected_value // empty')

        if [ -z "$SELECTED" ]; then
            echo '{"success": false, "error": "no selection"}'
            exit 0
        fi

        # Value format: "<tmux-session>|<session-path>" (from on_view)
        TMUX_NAME="${SELECTED%%|*}"
        SESS_PATH="${SELECTED#*|}"
        if [ "$SESS_PATH" = "$SELECTED" ]; then
            SESS_PATH="$HOME"
        fi

        # Create the tmux session if it doesn't exist
        if ! tmux has-session -t "=${TMUX_NAME}" 2>/dev/null; then
            tmux new-session -d -s "$TMUX_NAME" -c "$SESS_PATH" 2>&1 >&2 || true
        fi
        # Stamp the session path so `ez cd-to-session` can recover it.
        tmux set-option -t "=${TMUX_NAME}" -q @ez_session_path "${SESS_PATH}" 2>/dev/null || true

        # If the user's shell is inside tmux ($TMUX set), switch the current
        # client. Otherwise, attach in the current terminal — never call
        # switch-client without $TMUX, since tmux will switch some random
        # other client in another terminal.
        CMD="if [ -n \"\$TMUX\" ]; then tmux switch-client -t \"=${TMUX_NAME}\"; else tmux attach-session -t \"=${TMUX_NAME}\"; fi"
        jq -n --arg cmd "$CMD" '{success: true, post_shell_commands: [$cmd]}'
        ;;

    *)
        echo '{"success": true}'
        ;;
esac
