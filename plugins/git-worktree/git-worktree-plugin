#!/usr/bin/env bash
# git-worktree plugin for ez-workspaces
# Creates/removes git worktrees when sessions are created/deleted.
#
# Protocol: reads JSON request from stdin, writes JSON response to stdout.

set -euo pipefail

# Debug logger: writes to EZ_PLUGIN_DEBUG_LOG when set (injected by --debug).
_dbg_initialized=
dbg() {
    [ -n "${EZ_PLUGIN_DEBUG_LOG:-}" ] || return 0
    if [ -z "$_dbg_initialized" ]; then
        _dbg_initialized=1
        printf '=== git-worktree-plugin debug log (pid=%s hook=%s) ===\n' "$$" "${HOOK:-?}" >> "$EZ_PLUGIN_DEBUG_LOG"
    fi
    printf '%s\n' "$*" >> "$EZ_PLUGIN_DEBUG_LOG"
}

# Returns current time in milliseconds (portable: macOS lacks %N).
t_ms() {
    local out
    out=$(date +%s%3N)
    if [[ "$out" =~ ^[0-9]+$ ]]; then
        echo "$out"
    else
        echo $(( $(date +%s) * 1000 ))
    fi
}

# Read the full JSON request from stdin
REQUEST=$(cat)

HOOK=$(echo "$REQUEST" | jq -r '.hook')
REPO_PATH=$(echo "$REQUEST" | jq -r '.repo.path')
SESSION_NAME=$(echo "$REQUEST" | jq -r '.session.name // empty')
SESSION_PATH=$(echo "$REQUEST" | jq -r '.session.path // empty')
SESSION_IS_DEFAULT=$(echo "$REQUEST" | jq -r '.session.is_default // false')
PARENT_IS_DEFAULT=$(echo "$REQUEST" | jq -r '.session.parent_is_default // false')
PARENT_NAME=$(echo "$REQUEST" | jq -r '.session.parent_name // empty')
START_POINT_OVERRIDE=$(echo "$REQUEST" | jq -r '.session.start_point // empty')
IS_GIT=$(echo "$REQUEST" | jq -r '.repo.is_git // true')

# Fetch TTL in seconds: only refetch origin if the last fetch was older than this.
# Set to 0 to always fetch. Configurable via [plugin_settings.git-worktree] fetch_ttl.
FETCH_TTL=$(echo "$REQUEST" | jq -r '.config.user_config.fetch_ttl // 60')

# Absolute path to the git dir (used for the fetch timestamp file).
GIT_DIR_ABS=$(git -C "$REPO_PATH" rev-parse --absolute-git-dir 2>/dev/null || echo "$REPO_PATH/.git")
FETCH_STAMP="${GIT_DIR_ABS}/ez-fetch-stamp"

# Returns 0 (true) if we should fetch, 1 (false) if we can skip.
should_fetch() {
    [ "$FETCH_TTL" -le 0 ] && return 0
    [ ! -f "$FETCH_STAMP" ] && return 0
    local last now elapsed
    last=$(cat "$FETCH_STAMP" 2>/dev/null || echo 0)
    now=$(date +%s)
    elapsed=$(( now - last ))
    [ "$elapsed" -ge "$FETCH_TTL" ] && return 0
    dbg "fetch: skipped (cached, ${elapsed}s old, ttl=${FETCH_TTL}s)"
    return 1
}

dbg "hook=$HOOK repo=$REPO_PATH session=$SESSION_NAME is_default=$SESSION_IS_DEFAULT parent=$PARENT_NAME parent_is_default=$PARENT_IS_DEFAULT"

# Don't operate on non-git repos
if [ "$IS_GIT" = "false" ]; then
    dbg "skipping: non-git repo"
    echo '{"success": true}'
    exit 0
fi

# Don't create worktrees for the default "main" session
if [ "$SESSION_IS_DEFAULT" = "true" ]; then
    dbg "skipping: default session"
    echo '{"success": true}'
    exit 0
fi

# Worktree base directory: alongside the repo (sibling directory)
REPO_BASENAME=$(basename "$REPO_PATH")
WORKTREE_BASE=$(dirname "$REPO_PATH")/.ez/${REPO_BASENAME}
WORKTREE_PATH="${SESSION_PATH:-${WORKTREE_BASE}/${SESSION_NAME}}"

dbg "worktree_base=$WORKTREE_BASE worktree_path=$WORKTREE_PATH"

resolve_default_start_point() {
    if should_fetch; then
        local t0; t0=$(t_ms)
        echo "fetching origin/main and origin/master..." >&2
        dbg "fetch: start"
        git -C "$REPO_PATH" fetch origin main >&2 2>/dev/null || true
        git -C "$REPO_PATH" fetch origin master >&2 2>/dev/null || true
        if [ -n "$SESSION_NAME" ]; then
            dbg "fetch: also fetching origin/${SESSION_NAME}"
            git -C "$REPO_PATH" fetch origin "$SESSION_NAME" >&2 2>/dev/null || true
        fi
        date +%s > "$FETCH_STAMP" 2>/dev/null || true
        dbg "fetch: done ($(( $(t_ms) - t0 ))ms)"
    fi
    if git -C "$REPO_PATH" rev-parse --verify origin/main &>/dev/null; then
        dbg "start point: origin/main"
        echo "origin/main"
    elif git -C "$REPO_PATH" rev-parse --verify origin/master &>/dev/null; then
        dbg "start point: origin/master"
        echo "origin/master"
    else
        dbg "start point: HEAD (no origin/main or origin/master found)"
        echo "HEAD"
    fi
}

# Determine the start point for the new branch:
#   - Child of default session (or no parent): fetch + origin/main|master
#   - Child of non-default session with a worktree: HEAD of that worktree
#   - Child of non-default session without a worktree: fall back to default
resolve_start_point() {
    if [ "$PARENT_IS_DEFAULT" = "true" ] || [ -z "$PARENT_NAME" ]; then
        dbg "start point strategy: fetch (parent is default or absent)"
        resolve_default_start_point
    else
        local parent_worktree="${WORKTREE_BASE}/${PARENT_NAME}"
        if [ -d "$parent_worktree/.git" ] || [ -f "$parent_worktree/.git" ]; then
            dbg "start point strategy: HEAD of parent worktree ($parent_worktree)"
            git -C "$parent_worktree" rev-parse HEAD 2>/dev/null || resolve_default_start_point
        else
            dbg "start point strategy: fetch (parent worktree $parent_worktree not found)"
            resolve_default_start_point
        fi
    fi
}

json_error() {
    local err="$1"
    dbg "error: $err"
    printf '%s\n' "$err" >&2
    jq -n --arg err "$err" '{success: false, error: $err}'
}

worktree_for_branch() {
    local branch="refs/heads/$1"
    git -C "$REPO_PATH" worktree list --porcelain | awk -v branch="$branch" '
        $1 == "worktree" { path = substr($0, 10) }
        $1 == "branch" && $2 == branch { print path; exit }
    '
}

# If another mutates_session_path plugin already set the path, skip worktree creation
# but still do fetch + branch checkout at that path (it may be a standalone clone).
if [ "$HOOK" = "on_session_create" ] && [ -n "$SESSION_PATH" ]; then
    dbg "session path already set by another plugin ($SESSION_PATH), doing branch checkout only"
    if [ -d "$SESSION_PATH/.git" ] || [ -f "$SESSION_PATH/.git" ]; then
        REPO_PATH="$SESSION_PATH"
        GIT_DIR_ABS=$(git -C "$REPO_PATH" rev-parse --absolute-git-dir 2>/dev/null || echo "$REPO_PATH/.git")
        FETCH_STAMP="${GIT_DIR_ABS}/ez-fetch-stamp"

        BRANCH_NAME="${SESSION_NAME}"
        START_POINT=$(resolve_start_point)
        dbg "branch=$BRANCH_NAME start_point=$START_POINT"

        if git -C "$SESSION_PATH" show-ref --verify --quiet "refs/heads/${BRANCH_NAME}" 2>/dev/null; then
            dbg "branch exists, checking out"
            git -C "$SESSION_PATH" checkout "$BRANCH_NAME" >/dev/null 2>&1 || true
        elif git -C "$SESSION_PATH" rev-parse --verify "origin/${BRANCH_NAME}" >/dev/null 2>&1; then
            dbg "tracking remote branch origin/${BRANCH_NAME}"
            git -C "$SESSION_PATH" checkout --track -b "$BRANCH_NAME" "origin/${BRANCH_NAME}" >/dev/null 2>&1 || true
        else
            dbg "creating new branch from $START_POINT"
            git -C "$SESSION_PATH" checkout --no-track -b "$BRANCH_NAME" "$START_POINT" >/dev/null 2>&1 || true
        fi

        jq -n --arg branch "$BRANCH_NAME" \
            '{success: true, session_mutations: {plugin_state: {branch: $branch}}}'
    else
        dbg "session path is not a git repo, skipping"
        echo '{"success": true}'
    fi
    exit 0
fi

case "$HOOK" in
    on_session_create)
        mkdir -p "$WORKTREE_BASE"

        BRANCH_NAME="${SESSION_NAME}"
        dbg "branch=$BRANCH_NAME"

        t1=$(t_ms)
        # Check if branch already exists
        if git -C "$REPO_PATH" show-ref --verify --quiet "refs/heads/${BRANCH_NAME}" 2>/dev/null; then
            existing_worktree=$(worktree_for_branch "$BRANCH_NAME")
            if [ -n "$existing_worktree" ]; then
                json_error "Branch '$BRANCH_NAME' is already checked out at '$existing_worktree'. Register it with: ez session register '$existing_worktree' --repo '$REPO_BASENAME' --name '$SESSION_NAME'"
                exit 0
            fi
            dbg "worktree add: branch exists, checking out"
            if ! git_err=$(git -C "$REPO_PATH" worktree add "$WORKTREE_PATH" "$BRANCH_NAME" 2>&1 >/dev/null); then
                json_error "Failed to create worktree at '$WORKTREE_PATH' for existing branch '$BRANCH_NAME': $git_err"
                exit 0
            fi
        else
            if [ -n "$START_POINT_OVERRIDE" ]; then
                START_POINT="$START_POINT_OVERRIDE"
                dbg "start point: override=$START_POINT"
            else
                START_POINT=$(resolve_start_point)
            fi
            if git -C "$REPO_PATH" rev-parse --verify "origin/${BRANCH_NAME}" >/dev/null 2>&1; then
                dbg "worktree add: tracking remote branch origin/${BRANCH_NAME}"
                if ! git_err=$(git -C "$REPO_PATH" worktree add --track -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/${BRANCH_NAME}" 2>&1 >/dev/null); then
                    json_error "Failed to create worktree at '$WORKTREE_PATH' tracking 'origin/${BRANCH_NAME}': $git_err"
                    exit 0
                fi
            else
                dbg "worktree add: creating new branch from $START_POINT"
                if ! git_err=$(git -C "$REPO_PATH" worktree add --no-track -b "$BRANCH_NAME" "$WORKTREE_PATH" "$START_POINT" 2>&1 >/dev/null); then
                    json_error "Failed to create worktree at '$WORKTREE_PATH' from '$START_POINT': $git_err"
                    exit 0
                fi
            fi
        fi
        dbg "worktree add: done ($(( $(t_ms) - t1 ))ms)"

        # Return mutations to set the session's path
        jq -n \
            --arg path "$WORKTREE_PATH" \
            --arg branch "$BRANCH_NAME" \
            '{
                success: true,
                session_mutations: {
                    path: $path,
                    plugin_state: {
                        worktree_path: $path,
                        branch: $branch
                    }
                }
            }'
        ;;

    on_session_delete)
        if [ -d "$WORKTREE_PATH" ]; then
            t2=$(t_ms)
            dbg "worktree remove: $WORKTREE_PATH"
            if ! git -C "$REPO_PATH" worktree remove "$WORKTREE_PATH" --force >/dev/null 2>&1; then
                # git refuses to remove the worktree when CWD is inside it.
                # cd to the repo root and retry.
                dbg "worktree remove: git failed (likely cwd inside worktree), cding to repo and retrying"
                cd "$REPO_PATH"
                git -C "$REPO_PATH" worktree remove "$WORKTREE_PATH" --force >/dev/null 2>&1 || true
            fi
            dbg "worktree remove: done ($(( $(t_ms) - t2 ))ms)"
        else
            dbg "worktree path not found, nothing to remove: $WORKTREE_PATH"
        fi
        echo '{"success": true}'
        ;;

    *)
        echo '{"success": true}'
        ;;
esac
