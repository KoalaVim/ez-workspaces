#!/usr/bin/env bash
# kv plugin for ez-workspaces
# Manages KoalaVim (kv) environments per session.
# Each session gets its own kv env forked from a configurable source (default: main).
#
# Protocol: reads JSON request from stdin, writes JSON response to stdout.

set -euo pipefail

t_ms() {
    local out
    out=$(date +%s%3N)
    if [[ "$out" =~ ^[0-9]+$ ]]; then
        echo "$out"
    else
        echo $(( $(date +%s) * 1000 ))
    fi
}

_dbg_initialized=
dbg() {
    [ -n "${EZ_PLUGIN_DEBUG_LOG:-}" ] || return 0
    if [ -z "$_dbg_initialized" ]; then
        _dbg_initialized=1
        printf '=== kv-plugin debug log (pid=%s hook=%s) ===\n' "$$" "${HOOK:-?}" >> "$EZ_PLUGIN_DEBUG_LOG"
    fi
    printf '%s\n' "$*" >> "$EZ_PLUGIN_DEBUG_LOG"
}

REQUEST=$(cat)

HOOK=$(echo "$REQUEST" | jq -r '.hook')
REPO_NAME=$(echo "$REQUEST" | jq -r '.repo.path // empty' | xargs basename 2>/dev/null || echo "")
SESSION_NAME=$(echo "$REQUEST" | jq -r '.session.name // empty')
SESSION_IS_DEFAULT=$(echo "$REQUEST" | jq -r '.session.is_default // false')
SOURCE_ENV=$(echo "$REQUEST" | jq -r '.config.user_config.source_env // "main"')
REPOS=$(echo "$REQUEST" | jq -r '.config.user_config.repos // empty')

KV_ENV_NAME="$SESSION_NAME"

dbg "hook=$HOOK repo=$REPO_NAME session=$SESSION_NAME is_default=$SESSION_IS_DEFAULT source_env=$SOURCE_ENV repos=$REPOS kv_env=$KV_ENV_NAME"

# If repos is configured, only run on matching repos
if [ -n "$REPOS" ]; then
    match=false
    IFS=',' read -ra REPO_LIST <<< "$REPOS"
    for r in "${REPO_LIST[@]}"; do
        r=$(echo "$r" | xargs)
        if [ "$r" = "$REPO_NAME" ]; then
            match=true
            break
        fi
    done
    if [ "$match" = "false" ]; then
        dbg "repo '$REPO_NAME' not in repos list, skipping"
        echo '{"success": true}'
        exit 0
    fi
fi

if ! command -v kv &>/dev/null; then
    dbg "kv not found in PATH, skipping"
    echo '{"success": true}'
    exit 0
fi

case "$HOOK" in
    on_session_create)
        if [ "$SESSION_IS_DEFAULT" = "true" ]; then
            dbg "default session, skipping fork"
            echo '{"success": true}'
            exit 0
        fi

        if kv env list 2>/dev/null | grep -qx "$KV_ENV_NAME"; then
            dbg "kv env '$KV_ENV_NAME' already exists, reusing"
            echo "reusing existing env '$KV_ENV_NAME'" >&2
        else
            dbg "forking kv env: $SOURCE_ENV -> $KV_ENV_NAME"
            echo "forking env: $SOURCE_ENV → $KV_ENV_NAME..." >&2
            t0=$(t_ms)
            if ! fork_err=$(kv env fork "$SOURCE_ENV" "$KV_ENV_NAME" 2>&1); then
                dbg "fork failed: $fork_err"
                jq -n --arg err "kv env fork failed: $fork_err" '{success: false, error: $err}'
                exit 0
            fi
            echo "fork done ($(( $(t_ms) - t0 ))ms)" >&2
            dbg "fork complete"
        fi

        t1=$(t_ms)
        KVIM_PATH=$(kv env path "$KV_ENV_NAME" 2>/dev/null || echo "")
        echo "env path resolved ($(( $(t_ms) - t1 ))ms)" >&2
        dbg "kvim path: $KVIM_PATH"

        jq -n \
            --arg kv_env "$KV_ENV_NAME" \
            --arg kvim_path "$KVIM_PATH" \
            '{
                success: true,
                session_mutations: ({
                    env: {
                        KV_ENV: $kv_env
                    },
                    plugin_state: {
                        kv_env_name: $kv_env
                    }
                } + if $kvim_path != "" then { path: $kvim_path } else {} end)
            }'
        ;;

    on_session_delete)
        if [ "$SESSION_IS_DEFAULT" = "true" ]; then
            dbg "default session, skipping delete"
            echo '{"success": true}'
            exit 0
        fi

        dbg "deleting kv env: $KV_ENV_NAME"
        echo "deleting env '$KV_ENV_NAME'..." >&2
        td=$(t_ms)
        kv env delete --force "$KV_ENV_NAME" 2>/dev/null || {
            dbg "kv env delete failed or env not found (non-fatal)"
        }
        echo "delete done ($(( $(t_ms) - td ))ms)" >&2
        echo '{"success": true}'
        ;;

    on_session_enter)
        if [ "$SESSION_IS_DEFAULT" = "true" ]; then
            KV_ENV_NAME="$SOURCE_ENV"
            dbg "default session, using source env: $KV_ENV_NAME"
        fi

        jq -n \
            --arg kv_env "$KV_ENV_NAME" \
            '{
                success: true,
                session_mutations: {
                    env: {
                        KV_ENV: $kv_env
                    }
                }
            }'
        ;;

    on_session_rename)
        OLD_NAME=$(echo "$REQUEST" | jq -r '.rename_context.old_name // empty')
        NEW_NAME=$(echo "$REQUEST" | jq -r '.rename_context.new_name // empty')

        if [ -z "$OLD_NAME" ] || [ -z "$NEW_NAME" ]; then
            echo '{"success": true}'
            exit 0
        fi

        if [ "$SESSION_IS_DEFAULT" = "true" ]; then
            dbg "default session, skipping rename"
            echo '{"success": true}'
            exit 0
        fi

        dbg "renaming kv env: $OLD_NAME -> $NEW_NAME"
        echo "renaming env: $OLD_NAME → $NEW_NAME..." >&2
        tr=$(t_ms)
        kv env rename "$OLD_NAME" "$NEW_NAME" 2>/dev/null || {
            dbg "kv env rename failed (non-fatal)"
        }
        echo "rename done ($(( $(t_ms) - tr ))ms)" >&2

        jq -n \
            --arg kv_env "$NEW_NAME" \
            '{
                success: true,
                session_mutations: {
                    env: {
                        KV_ENV: $kv_env
                    },
                    plugin_state: {
                        kv_env_name: $kv_env
                    }
                }
            }'
        ;;

    *)
        echo '{"success": true}'
        ;;
esac
